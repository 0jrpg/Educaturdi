# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local no GitHub — ele já está no .gitignore.

# Encontre esses valores em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ⚠️ CHAVE SECRETA — NUNCA tem o prefixo NEXT_PUBLIC_, NUNCA vai pro navegador.
# Usada apenas nas API Routes do servidor (ex: criar usuários).
# Encontre em: Project Settings → API → service_role (clique em "Reveal")
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
